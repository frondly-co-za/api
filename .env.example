MONGODB_URI=mongodb://user:password@localhost:27017/frondly-dev
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.frondly.co.za
CORS_ORIGIN=http://localhost:5173,https://frondly.co.za
PHOTO_STORAGE_PATH=./uploads
# Used to sign photo URLs
PHOTO_SIGNING_SECRET=replace-with-a-long-random-secret

# Trusted reverse proxy IP or CIDR (e.g. 192.168.1.50 or 192.168.1.0/24)
# Set to the LAN IP of the reverse proxy host so X-Forwarded-For is only trusted from that source.
# Leave unset in local dev (no proxy in front of the API).
# TRUSTED_PROXY_IP=192.168.1.50

# Port (optional, default: 4500)
# PORT=4500

# Logging (optional)
# LOG_LEVEL=info            # trace | debug | info | warn | error (default: info)
# LOG_FILE=./logs/api.log   # if set, logs are written here (rolling, 10 MB / 5 files) in addition to stdout
